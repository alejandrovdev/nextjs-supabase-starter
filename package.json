{
  "name": "nextjs-supabase-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:studio": "tsx scripts/open-db-studio.ts",
    "db:migrations:generate": "drizzle-kit generate",
    "db:migrations:list": "supabase migration list",
    "db:migrations:up": "supabase migration up",
    "db:migrations:down": "supabase migration down",
    "db:types": "npx supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "mailpit": "tsx scripts/open-mailpit-client.ts",
    "openapi": "tsx scripts/open-openapi.ts",
    "storage:sync": "supabase seed buckets",
    "test": "vitest run",
    "test:unit": "vitest run service.test",
    "test:integration": "vitest run procedures.test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@orpc/client": "^1.13.13",
    "@orpc/json-schema": "^1.13.13",
    "@orpc/openapi": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/tanstack-query": "^1.13.13",
    "@orpc/zod": "^1.13.13",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.102.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.554.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tanstack/eslint-plugin-query": "^5.96.2",
    "@types/node": "^20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.3",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.16",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "open": "^11.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.88.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,mjs,mts,cjs,cts}": [
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
